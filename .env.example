# Database
# Dev (local): uses host port 5532 mapped to container
DATABASE_URL=postgresql://postgres:password@localhost:5532/gamedar
# Prod (Docker): uses internal Docker network, default port
# DATABASE_URL=postgresql://postgres:password@db:5432/gamedar

# Docker Compose DB credentials
POSTGRES_DB=gamedar
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# IGDB creds
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Anthropic creds
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Rate limiting
DAILY_GENERATION_LIMIT=5

NEXT_PUBLIC_APP_URL=http://localhost:3000
