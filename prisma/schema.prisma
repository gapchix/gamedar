generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Calendar {
  id           String         @id @default(uuid())
  name         String
  platform     String
  genres       String[]
  hoursPerWeek Int
  timePeriod   String
  playStyle    String
  createdAt    DateTime       @default(now())
  games        CalendarGame[]

  @@map("calendars")
}

model CalendarGame {
  id             String   @id @default(uuid())
  calendarId     String
  igdbId         Int
  title          String
  coverUrl       String?
  estimatedHours Float
  startDate      DateTime
  endDate        DateTime
  order          Int
  calendar       Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@map("calendar_games")
}